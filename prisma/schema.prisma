generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FreightRate {
  id        Int      @id @default(autoincrement())
  date      DateTime
  segment   String
  route     String
  rate      Float
  change    Float    @default(0)
  source    String   @default("searates")
  createdAt DateTime @default(now())

  @@unique([date, segment, route])
  @@index([segment])
  @@index([date])
}

model Vessel {
  imo       String   @id
  name      String
  segment   String
  dwt       Int
  built     Int
  flag      String
  owner     String
  operator  String
  status    String   @default("Active")
  lat       Float?
  lon       Float?
  speed     Float?
  heading   Float?
  destination String?
  eta       String?
  updatedAt DateTime @default(now())

  @@index([segment])
  @@index([operator])
}

model Newbuilding {
  id            Int      @id @default(autoincrement())
  vesselName    String?
  segment       String
  dwt           Int
  yard          String
  owner         String
  orderDate     DateTime
  deliveryDate  DateTime
  status        String   @default("On Order")
  createdAt     DateTime @default(now())

  @@index([segment])
  @@index([deliveryDate])
}

model MacroSeries {
  id          Int      @id @default(autoincrement())
  seriesId    String
  date        DateTime
  value       Float
  title       String
  unit        String   @default("")
  source      String   @default("FRED")
  createdAt   DateTime @default(now())

  @@unique([seriesId, date])
  @@index([seriesId])
}

model ApiCache {
  key       String   @id
  data      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
